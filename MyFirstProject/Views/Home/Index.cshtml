
@{
    ViewData["Title"] = "Home Page";
}
<style>

    *{
        box-sizing:border-box;
    }
    body {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(to right, #0b132b, #1c2541);
        color: white;
    }

    /* Top Section */
    .home-dev {
        text-align: center;
        padding: 60px 20px 30px;
    }

        .home-dev h1 {
            font-size: 48px;
            color: #5bc0eb;
            margin-bottom: 10px;
        }

        .home-dev a {
            text-decoration: none;
            color: #fff;
            background: #5bc0eb;
            padding: 10px 20px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .home-dev a:hover {
                background: #3a86ff;
            }

        .home-dev p {
            font-size: 18px;
            margin-top: 15px;
        }

    /* Divider */
    hr {
        width: 60%;
        border: 1px solid #5bc0eb;
        margin: 30px auto;
    }

    /* Image Section */
    .container1 {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 0;
    }

    /* Card Style */
    .image-box {
        background: rgba(255, 255, 255, 0.05);
        padding: 25px;
        border-radius: 20px;
        text-align: center;
        width: 350px;
        backdrop-filter: blur(10px);
        box-shadow: 0 0 25px rgba(91, 192, 235, 0.5);
        transition: 0.3s;
      
    }

        .image-box:hover {
            transform: scale(1.02);
            box-shadow: 0 0 40px rgba(91, 192, 235, 0.9);
        }

        .image-box img {
            width: 100%;
            border-radius: 15px;
     
        }

        /* Quote Text */
        .image-box h3 {
            margin-top: 20px;
            font-weight: 400;
            line-height: 1.3;
        }

    /* Button */
    .btn {
        margin-top: 20px;
        padding: 10px 25px;
        border: none;
        border-radius: 8px;
        background: #5bc0eb;
        color: white;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn:hover {
            background: #3a86ff;
        }
     

</style>
<html>
   <head>
      <title>Index</title>
   </head>
   
   <body>
       <div class="home-dev">

           <h1>WelCome To ILS</h1><br />
           <a href="/Home/StudentDetail"><b>Check Student Detail</b></a>
           <a href="/Home/Form"><b>H-Form</b></a>
           <p>In This Seasion You Will Learn About <b>ASP.NET CORE</b></p>
       </div>
       <hr />
       <div  class="container1">
           <div class="image-box">
               <img src="~/Image/index.jpeg" alt="ils-image" />
               <h3>
                “Empowering minds <br /> through <b style="color:red">CODE</b>, <br>
                   shaping the future <br />with technology.”
               </h3>
               <button type="submit" class="btn">Get Start</button>

           </div>
       </div>

   </body>

   
</html>
